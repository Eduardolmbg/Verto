# === LLM Provider ===
# Escolha: groq, gemini, claude, openai
LLM_PROVIDER=groq

# === API Keys (usar a do provider escolhido) ===
# Groq (free): https://console.groq.com/keys
# Gemini (free): https://aistudio.google.com/apikey
# Claude: https://console.anthropic.com/settings/keys
# OpenAI: https://platform.openai.com/api-keys
LLM_API_KEY=

# === Modelo (opcional, usa default se nao especificar) ===
# Groq: llama-3.3-70b-versatile, deepseek-r1-distill-llama-70b, meta-llama/llama-4-scout-17b-16e-instruct, llama-3.1-8b-instant, qwen/qwen3-32b
# Gemini: gemini-2.5-flash, gemini-2.5-flash-lite, gemini-2.0-flash
# Claude: claude-sonnet-4-6, claude-haiku-4-5-20251001, claude-opus-4-6
# OpenAI: gpt-4.1, gpt-4.1-mini, gpt-4.1-nano, o3, o4-mini
LLM_MODEL=

# === brapi.dev (fallback, opcional) ===
BRAPI_TOKEN=

# === Pesquisa web ===
SEARCH_MAX_RESULTS=8
